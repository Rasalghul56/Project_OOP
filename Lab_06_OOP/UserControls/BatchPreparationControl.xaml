<UserControl x:Class="Lab_06_OOP.UserControls.BatchPreparationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border Padding="10" Margin="0,8,0,0" BorderBrush="#FFD7D7D7" BorderThickness="1" CornerRadius="8">
        <StackPanel>
            <TextBlock Text="Подготовка партии десертов" FontWeight="Bold"/>
            <TextBlock Margin="0,6,0,2" Text="Размер партии:"/>
            <TextBox Text="{Binding BatchSize, ElementName=Root}" />
            <TextBlock Margin="0,6,0,2" Text="Максимум в смену:"/>
            <TextBox Text="{Binding MaxBatchSize, ElementName=Root}" />
            <CheckBox Margin="0,6,0,0"
                      Content="Диетический режим"
                      IsChecked="{Binding DietMode, ElementName=Root}" />
            <WrapPanel Margin="0,8,0,0">
                <Button Content="Direct" Click="TasteCheckButton_Click" Margin="0,0,8,0"/>
                <Button Content="Tunnel + Bubble" Click="PrepareBatchButton_Click"/>
            </WrapPanel>
        </StackPanel>
    </Border>
</UserControl>