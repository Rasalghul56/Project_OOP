<UserControl x:Class="Confectionery.Views.Admin.OrderManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource PrimaryFont}">
    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="{DynamicResource AdminOrder_Title}"
                   Style="{StaticResource SectionHeader}"/>

        <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{DynamicResource AdminOrder_Status}"
                           VerticalAlignment="Center" FontSize="13"
                           Foreground="{DynamicResource TextMediumBrush}" Margin="0,0,10,0"/>
                <ComboBox ItemsSource="{Binding StatusFilter}"
                          SelectedItem="{Binding SelectedStatusFilter}" Width="160"/>
                <TextBlock Text="{DynamicResource AdminOrder_DateFrom}"
                           VerticalAlignment="Center" FontSize="13"
                           Foreground="{DynamicResource TextMediumBrush}" Margin="16,0,10,0"/>
                <DatePicker SelectedDate="{Binding DateFrom}" Width="130" VerticalAlignment="Center"/>
                <TextBlock Text="{DynamicResource AdminOrder_DateTo}"
                           VerticalAlignment="Center" FontSize="13"
                           Foreground="{DynamicResource TextMediumBrush}" Margin="10,0"/>
                <DatePicker SelectedDate="{Binding DateTo}" Width="130" VerticalAlignment="Center"/>
                <Button Content="{DynamicResource AdminOrder_Reset}"
                        Style="{StaticResource SecondaryButton}"
                        Padding="12,7" Margin="14,0,0,0"
                        Command="{Binding ResetFilterCommand}"/>
            </StackPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <DataGrid ItemsSource="{Binding Orders}"
                          SelectedItem="{Binding SelectedOrder}"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="№" Binding="{Binding OrderNumber}" Width="70"/>
                        <DataGridTextColumn Header="{DynamicResource AdminOrder_Client}"
                                            Binding="{Binding User.Name}" Width="*"/>
                        <DataGridTextColumn Header="{DynamicResource AdminOrder_DateFrom}"
                                            Binding="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy}'}"
                                            Width="90"/>
                        <DataGridTextColumn Header="Сумма"
                                            Binding="{Binding TotalPrice, StringFormat='{}{0:F2} Br'}"
                                            Width="100"/>
                        <DataGridTextColumn Header="{DynamicResource AdminOrder_Status}"
                                            Binding="{Binding Status, Converter={StaticResource OrderStatusConverter}}"
                                            Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Детали и управление -->
            <Border Grid.Column="2" Style="{StaticResource Card}" VerticalAlignment="Top"
                    Visibility="{Binding SelectedOrder, Converter={StaticResource NullToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource AdminOrder_Manage}"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource TextDarkBrush}" Margin="0,0,0,12"/>

                    <TextBlock Style="{StaticResource LabelText}"
                               Text="{DynamicResource AdminOrder_Client}"/>
                    <TextBlock Text="{Binding SelectedOrder.User.Name}"
                               FontSize="13" Foreground="{DynamicResource TextDarkBrush}"
                               Margin="0,0,0,8"/>

                    <TextBlock Style="{StaticResource LabelText}"
                               Text="{DynamicResource AdminOrder_Delivery}"/>
                    <TextBlock Text="{Binding SelectedOrder.DeliveryType,
                                   Converter={StaticResource DeliveryTypeConverter}}"
                               FontSize="13" Foreground="{DynamicResource TextDarkBrush}"
                               Margin="0,0,0,8"/>

                    <!-- Адрес доставки (только если доставка) -->
                    <StackPanel Visibility="{Binding SelectedOrder.DeliveryAddress,
                                    Converter={StaticResource NullToVisibilityConverter}}">
                        <TextBlock Style="{StaticResource LabelText}"
                                   Text="{DynamicResource AdminOrder_Address}"/>
                        <TextBlock Text="{Binding SelectedOrder.DeliveryAddress}"
                                   FontSize="13" Foreground="{DynamicResource TextDarkBrush}"
                                   TextWrapping="Wrap" Margin="0,0,0,8"/>
                        <TextBlock Style="{StaticResource LabelText}"
                                   Text="{DynamicResource AdminOrder_Phone}"/>
                        <TextBlock Text="{Binding SelectedOrder.DeliveryPhone}"
                                   FontSize="13" Foreground="{DynamicResource TextDarkBrush}"
                                   Margin="0,0,0,8"/>
                    </StackPanel>

                    <!-- Точка самовывоза -->
                    <StackPanel Visibility="{Binding SelectedOrder.PickupLocation,
                                    Converter={StaticResource NullToVisibilityConverter}}">
                        <TextBlock Style="{StaticResource LabelText}" Text="Точка самовывоза"/>
                        <TextBlock Text="{Binding SelectedOrder.PickupLocation}"
                                   FontSize="13" Foreground="{DynamicResource TextDarkBrush}"
                                   Margin="0,0,0,8"/>
                    </StackPanel>

                    <TextBlock Style="{StaticResource LabelText}"
                               Text="{DynamicResource AdminOrder_ChangeStatus}"/>
                    <ComboBox ItemsSource="{Binding AvailableStatuses}"
                              SelectedItem="{Binding NewStatus}"
                              Margin="0,0,0,12"/>

                    <Button Content="{DynamicResource AdminOrder_SaveStatus}"
                            Style="{StaticResource PrimaryButton}" Height="40"
                            Command="{Binding UpdateStatusCommand}"/>

                    <Separator Margin="0,12"/>

                    <TextBlock Style="{StaticResource LabelText}"
                               Text="{DynamicResource AdminOrder_Composition}"/>
                    <ItemsControl ItemsSource="{Binding SelectedOrder.OrderItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,6">
                                    <TextBlock Text="{Binding Product.Name}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextDarkBrush}"/>
                                    <TextBlock HorizontalAlignment="Right"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextMediumBrush}">
                                        <Run Text="{Binding Quantity}"/>
                                        <Run Text=" шт."/>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
