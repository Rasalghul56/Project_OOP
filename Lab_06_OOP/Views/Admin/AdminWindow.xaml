<Window x:Class="Confectionery.Views.Admin.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Confectionery.ViewModels.Admin"
        xmlns:v="clr-namespace:Confectionery.Views.Admin"
        Title="Кондитерская — Администратор"
        Width="1280" Height="760"
        MinWidth="1000" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        FontFamily="{StaticResource PrimaryFont}"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <v:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProductManagementViewModel}">
            <v:ProductManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:OrderManagementViewModel}">
            <v:OrderManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReviewManagementViewModel}">
            <v:ReviewManagementView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ════════════════ Sidebar ════════════════ -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <DockPanel>
                <!-- Лого -->
                <StackPanel DockPanel.Dock="Top" Margin="0,24,0,20"
                            HorizontalAlignment="Center">
                    <TextBlock Text="🍰" FontSize="38" HorizontalAlignment="Center"/>
                    <TextBlock Text="Кондитерская" Foreground="White"
                               FontSize="14" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    <Border Background="#40FFFFFF" CornerRadius="10"
                            Padding="10,3" Margin="12,6,12,0">
                        <TextBlock Text="Администратор" Foreground="#E8D0F0"
                                   FontSize="11" HorizontalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <Separator DockPanel.Dock="Top" Background="#40FFFFFF" Margin="16,0"/>

                <!-- Навигация -->
                <StackPanel DockPanel.Dock="Top" Margin="0,12,0,0">
                    <Button Style="{StaticResource SidebarButton}"
                            Command="{Binding ShowDashboardCommand}">
                        <TextBlock Text="{DynamicResource Admin_Dashboard}"/>
                    </Button>
                    <Button Style="{StaticResource SidebarButton}"
                            Command="{Binding ShowProductsCommand}">
                        <TextBlock Text="{DynamicResource Admin_Products}"/>
                    </Button>
                    <Button Style="{StaticResource SidebarButton}"
                            Command="{Binding ShowOrdersCommand}">
                        <TextBlock Text="{DynamicResource Admin_Orders}"/>
                    </Button>
                    <Button Style="{StaticResource SidebarButton}"
                            Command="{Binding ShowReviewsCommand}">
                        <TextBlock Text="{DynamicResource Admin_Reviews}"/>
                    </Button>
                </StackPanel>

                <!-- Нижняя часть: тема / язык / выход -->
                <StackPanel DockPanel.Dock="Bottom" Margin="12,0,12,20">
                    <Separator Background="#40FFFFFF" Margin="4,0,4,10"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Style="{StaticResource SidebarButton}"
                                Command="{Binding ToggleThemeCommand}"
                                HorizontalContentAlignment="Center"
                                Padding="6,8">
                            <TextBlock Text="{DynamicResource Btn_Theme}" FontSize="12"/>
                        </Button>
                        <Button Grid.Column="2"
                                Style="{StaticResource SidebarButton}"
                                Command="{Binding ToggleLangCommand}"
                                HorizontalContentAlignment="Center"
                                Padding="6,8">
                            <TextBlock Text="{DynamicResource Btn_Lang}" FontSize="12"/>
                        </Button>
                    </Grid>
                    <Button Style="{StaticResource SidebarButton}"
                            Command="{Binding LogoutCommand}"
                            HorizontalContentAlignment="Center" Padding="6,8">
                        <TextBlock Text="{DynamicResource Nav_Logout}" FontSize="12" Foreground="#FF8888"/>
                    </Button>
                </StackPanel>

                <Grid/>
            </DockPanel>
        </Border>

        <!-- ════════════════ Content ════════════════ -->
        <Border Grid.Column="1" Background="{DynamicResource BackgroundBrush}">
            <ContentControl Content="{Binding CurrentView}" Margin="24"
                            Style="{StaticResource FadeContentControl}"/>
        </Border>
    </Grid>
</Window>
