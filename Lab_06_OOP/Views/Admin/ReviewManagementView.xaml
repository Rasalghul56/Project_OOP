<UserControl x:Class="Confectionery.Views.Admin.ReviewManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource PrimaryFont}">
    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="{DynamicResource Reviews_Title}"
                   Style="{StaticResource SectionHeader}"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <ListBox Grid.Column="0"
                     ItemsSource="{Binding Reviews}"
                     SelectedItem="{Binding SelectedReview}"
                     Background="Transparent" BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Padding="14,12" Margin="0,0,0,8">
                            <StackPanel>
                                <Grid>
                                    <StackPanel>
                                        <TextBlock FontWeight="Bold" FontSize="13"
                                                   Foreground="{DynamicResource TextDarkBrush}">
                                            <Run Text="{Binding User.Name}"/>
                                            <Run Text=" · "/>
                                            <Run Text="{Binding Product.Name}"
                                                 Foreground="{StaticResource AccentBrush}"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Rating, StringFormat='⭐ {0}'}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextMediumBrush}"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <TextBlock HorizontalAlignment="Right"
                                               Text="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy}'}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextLightBrush}"
                                               VerticalAlignment="Top"/>
                                </Grid>
                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextDarkBrush}"
                                           Margin="0,6,0,0"/>
                                <Border Visibility="{Binding AdminReply,
                                            Converter={StaticResource NullToVisibilityConverter}}"
                                        Background="{StaticResource AccentLightBrush}"
                                        CornerRadius="6" Padding="10,6" Margin="0,8,0,0">
                                    <TextBlock Foreground="{StaticResource AccentBrush}" FontSize="12">
                                        <Run Text="{DynamicResource Reviews_AdminReply}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding AdminReply}"/>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border Grid.Column="2" Style="{StaticResource Card}" VerticalAlignment="Top"
                    Visibility="{Binding SelectedReview, Converter={StaticResource NullToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Reviews_ReplyTitle}"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource TextDarkBrush}" Margin="0,0,0,12"/>

                    <TextBlock Style="{StaticResource LabelText}"
                               Text="{DynamicResource Reviews_ReviewText}"/>
                    <TextBlock Text="{Binding SelectedReview.Text}" TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="{DynamicResource TextMediumBrush}"
                               Margin="0,0,0,12"/>

                    <TextBlock Style="{StaticResource LabelText}"
                               Text="{DynamicResource Reviews_YourReply}"/>
                    <TextBox Style="{StaticResource ModernTextBox}"
                             Text="{Binding AdminReply, UpdateSourceTrigger=PropertyChanged}"
                             Height="80" TextWrapping="Wrap"
                             VerticalContentAlignment="Top" Padding="10,8"
                             Margin="0,0,0,12"/>

                    <Button Content="{DynamicResource Reviews_SendReply}"
                            Style="{StaticResource PrimaryButton}" Height="40"
                            Command="{Binding SendReplyCommand}"/>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
