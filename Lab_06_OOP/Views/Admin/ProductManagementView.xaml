<UserControl x:Class="Confectionery.Views.Admin.ProductManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource PrimaryFont}">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{DynamicResource Admin_Products}"
                           Style="{StaticResource SectionHeader}" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="{DynamicResource Prod_AddBtn}"
                            Style="{StaticResource PrimaryButton}"
                            Padding="16,10" VerticalAlignment="Center"
                            Command="{Binding AddNewCommand}"/>
                    <Button Content="🔄" Style="{StaticResource IconButton}"
                            Width="36" Height="36" FontSize="16"
                            VerticalAlignment="Center" Margin="8,0,0,0"
                            Command="{Binding RefreshCommand}" ToolTip="Обновить"/>
                </StackPanel>
            </Grid>
            <Grid>
                <TextBox Style="{StaticResource ModernTextBox}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Padding="36,0,36,0" Height="38"/>
                <TextBlock Text="{DynamicResource Prod_Search}"
                           VerticalAlignment="Center" Margin="12,0"
                           Foreground="{DynamicResource TextLightBrush}"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SearchText}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <Button Content="✕" Style="{StaticResource IconButton}"
                        Width="30" Height="30" FontSize="12"
                        HorizontalAlignment="Right" Margin="0,0,4,0"
                        Command="{Binding ClearSearchCommand}"
                        Visibility="{Binding HasSearchText, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </StackPanel>

        <Border DockPanel.Dock="Top"
                Background="{StaticResource AccentLightBrush}"
                CornerRadius="8" Padding="12,8" Margin="0,0,0,12"
                Visibility="{Binding StatusMessage, Converter={StaticResource NullToVisibilityConverter}}">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <DataGrid ItemsSource="{Binding Products}"
                          SelectedItem="{Binding SelectedProduct}"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource Prod_Name}"
                                            Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="{DynamicResource Prod_Category}"
                                            Binding="{Binding Category.Name}" Width="110"/>
                        <DataGridTextColumn Header="{DynamicResource Prod_Price}"
                                            Binding="{Binding Price, StringFormat='{}{0:F2} Br'}" Width="90"/>
                        <DataGridTextColumn Header="{DynamicResource Prod_Weight}"
                                            Binding="{Binding Weight}" Width="70"/>
                        <DataGridCheckBoxColumn Header="{DynamicResource Prod_Available}"
                                                Binding="{Binding IsAvailable}" Width="80"/>
                        <DataGridTemplateColumn Header="{DynamicResource Prod_Image}" Width="56">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Image Source="{Binding ImagePath, Converter={StaticResource ImagePathConverter}}"
                                           Width="40" Height="40" Stretch="UniformToFill"
                                           Visibility="{Binding ImagePath, Converter={StaticResource NullToVisibilityConverter}}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Card}" VerticalAlignment="Stretch">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Prod_FormTitle}"
                               FontSize="15" FontWeight="Bold"
                               Foreground="{DynamicResource TextDarkBrush}" Margin="0,0,0,14"/>

                    <TextBlock Text="{DynamicResource Prod_Name}" Style="{StaticResource LabelText}"/>
                    <TextBox Style="{StaticResource ModernTextBox}"
                             Text="{Binding FormName, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsEditing}" Margin="0,0,0,10"/>

                    <TextBlock Text="{DynamicResource Prod_Category}" Style="{StaticResource LabelText}"/>
                    <ComboBox ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding FormCategory}"
                              DisplayMemberPath="Name"
                              IsEnabled="{Binding IsEditing}"
                              Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Prod_Price}" Style="{StaticResource LabelText}"/>
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Text="{Binding FormPrice, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsEditing}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{DynamicResource Prod_Weight}" Style="{StaticResource LabelText}"/>
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Text="{Binding FormWeight, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsEditing}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="{DynamicResource Prod_Desc}" Style="{StaticResource LabelText}"/>
                    <TextBox Style="{StaticResource ModernTextBox}"
                             Text="{Binding FormDescription, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsEditing}"
                             Height="60" TextWrapping="Wrap"
                             VerticalContentAlignment="Top" Padding="10,8" Margin="0,0,0,10"/>

                    <TextBlock Text="{DynamicResource Prod_Comp}" Style="{StaticResource LabelText}"/>
                    <TextBox Style="{StaticResource ModernTextBox}"
                             Text="{Binding FormComposition, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsEditing}"
                             Height="50" TextWrapping="Wrap"
                             VerticalContentAlignment="Top" Padding="10,8" Margin="0,0,0,10"/>


                    <TextBlock Text="{DynamicResource Prod_Image}" Style="{StaticResource LabelText}"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Style="{StaticResource ModernTextBox}"
                                 Text="{Binding FormImagePath, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="True"
                                 IsEnabled="{Binding IsEditing}"
                                 ToolTip="{Binding FormImagePath}"/>
                        <Button Grid.Column="2"
                                Content="📂 Обзор"
                                Style="{StaticResource SecondaryButton}"
                                Height="38" Padding="10,0"
                                IsEnabled="{Binding IsEditing}"
                                Command="{Binding BrowseImageCommand}"/>
                    </Grid>

                    <Border CornerRadius="6" Margin="0,0,0,10" Height="100"
                            Background="{DynamicResource SurfaceBrush}"
                            Visibility="{Binding FormImagePath, Converter={StaticResource ImageFileExistsConverter}}">
                        <Image Source="{Binding FormImagePath, Converter={StaticResource ImagePathConverter}}"
                               Stretch="Uniform" Margin="4"/>
                    </Border>

                    <CheckBox Content="{DynamicResource Prod_Available}"
                              IsChecked="{Binding FormIsAvailable}"
                              IsEnabled="{Binding IsEditing}"
                              FontSize="13"
                              Foreground="{DynamicResource TextDarkBrush}"
                              Margin="0,0,0,12"/>

                    <TextBlock Text="{Binding FormError}"
                               Style="{StaticResource ErrorText}"
                               Visibility="{Binding FormError, Converter={StaticResource NullToVisibilityConverter}}"
                               Margin="0,0,0,8"/>

                    <StackPanel Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Button Content="{DynamicResource Prod_Save}"
                                Style="{StaticResource PrimaryButton}"
                                Height="40" Margin="0,0,0,8"
                                Command="{Binding SaveCommand}"/>
                        <Button Content="{DynamicResource Prod_Cancel}"
                                Style="{StaticResource DangerButton}"
                                Height="36"
                                Command="{Binding CancelCommand}"/>
                    </StackPanel>

                    <StackPanel Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <Button Content="{DynamicResource Prod_Edit}"
                                Style="{StaticResource SecondaryButton}"
                                Height="40" Margin="0,0,0,8"
                                Command="{Binding EditCommand}"/>
                        <Button Content="{DynamicResource Prod_Delete}"
                                Style="{StaticResource DangerButton}"
                                Height="36"
                                Command="{Binding DeleteCommand}"/>
                    </StackPanel>
                </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
