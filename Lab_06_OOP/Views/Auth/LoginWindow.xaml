<Window x:Class="Confectionery.Views.Auth.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:h="clr-namespace:Confectionery.Helpers"
        Title="Кондитерская — Вход"
        Width="900" Height="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="{StaticResource PrimaryFont}">

    <Window.Resources>
        <!-- Локальные цвета тёплой темы auth -->
        <SolidColorBrush x:Key="AuthBg1" Color="#F2E8DE"/>
        <SolidColorBrush x:Key="AuthBg2" Color="#E8D5C0"/>
        <SolidColorBrush x:Key="AuthAccent" Color="#D6953D"/>
        <SolidColorBrush x:Key="AuthDark"   Color="#5A3426"/>
        <SolidColorBrush x:Key="AuthLight"  Color="#F5C6C0"/>
    </Window.Resources>

    <!-- Тень всего окна -->
    <Border CornerRadius="20" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect Color="#80000000" BlurRadius="40" ShadowDepth="10" Opacity="0.35"/>
        </Border.Effect>
        <Grid>
            <!-- ── Фон — тёплый градиент ── -->
            <Border CornerRadius="20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#F2E8DE" Offset="0"/>
                        <GradientStop Color="#E8D5C0" Offset="0.5"/>
                        <GradientStop Color="#D6B896" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Декоративные круги на фоне -->
            <Ellipse Width="300" Height="300" Opacity="0.12"
                     HorizontalAlignment="Left" VerticalAlignment="Top"
                     Margin="-80,-100,0,0">
                <Ellipse.Fill>
                    <SolidColorBrush Color="#D6953D"/>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse Width="200" Height="200" Opacity="0.10"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom"
                     Margin="80,0,0,-60">
                <Ellipse.Fill>
                    <SolidColorBrush Color="#5A3426"/>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse Width="160" Height="160" Opacity="0.08"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-40,-40,0">
                <Ellipse.Fill>
                    <SolidColorBrush Color="#D6953D"/>
                </Ellipse.Fill>
            </Ellipse>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="400"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── Левая: брендинг ── -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center"
                            HorizontalAlignment="Center" Margin="40">
                    <!-- Иконка в круге -->
                    <Border Width="90" Height="90" CornerRadius="45"
                            HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#D6953D" Offset="0"/>
                                <GradientStop Color="#B87A2E" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#80D6953D" BlurRadius="18" ShadowDepth="0"/>
                        </Border.Effect>
                        <TextBlock Text="🍰" FontSize="42"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Кондитерская" FontSize="28" FontWeight="Bold"
                               Foreground="#5A3426" HorizontalAlignment="Center"/>
                    <TextBlock Text="Sweet Moments" FontSize="13"
                               Foreground="#C4906B" HorizontalAlignment="Center"
                               Margin="0,4,0,24"/>

                    <!-- Десертные элементы -->
                    <WrapPanel HorizontalAlignment="Center" Margin="0,0,0,24">
                        <TextBlock Text="🍩" FontSize="22" Margin="6,0" Opacity="0.8"/>
                        <TextBlock Text="🎂" FontSize="22" Margin="6,0" Opacity="0.8"/>
                        <TextBlock Text="🍪" FontSize="22" Margin="6,0" Opacity="0.8"/>
                        <TextBlock Text="🍫" FontSize="22" Margin="6,0" Opacity="0.8"/>
                        <TextBlock Text="🧁" FontSize="22" Margin="6,0" Opacity="0.8"/>
                    </WrapPanel>

                    <TextBlock TextWrapping="Wrap" TextAlignment="Center"
                               FontSize="12" Foreground="#9A7060" LineHeight="20"
                               MaxWidth="300">
                        Авторские десерты из натуральных ингредиентов с доставкой по Минску
                    </TextBlock>
                </StackPanel>

                <!-- ── Правая: стеклянная карточка формы ── -->
                <Border Grid.Column="1" CornerRadius="18" Margin="0,30,30,30"
                        ClipToBounds="False">
                    <Border.Background>
                        <SolidColorBrush Color="#FFFAF6F0" Opacity="0.92"/>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#60000000" BlurRadius="24" ShadowDepth="6" Opacity="0.18"/>
                    </Border.Effect>
                    <Border CornerRadius="18" Background="#F7F0E8" ClipToBounds="True">
                        <!-- Тонкая цветная полоска сверху -->
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Height="4" CornerRadius="18,18,0,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#D6953D" Offset="0"/>
                                        <GradientStop Color="#F5C6C0" Offset="0.5"/>
                                        <GradientStop Color="#D6953D" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="40,30,40,36">

                                    <TextBlock Text="Добро пожаловать!" FontSize="22" FontWeight="Bold"
                                               Foreground="#5A3426" Margin="0,0,0,4"/>
                                    <TextBlock Text="Войдите, чтобы продолжить" FontSize="13"
                                               Foreground="#9A7060" Margin="0,0,0,28"/>

                                    <!-- Email -->
                                    <TextBlock Text="Email" FontSize="11" FontWeight="SemiBold"
                                               Foreground="#9A7060" Margin="0,0,0,4"/>
                                    <Border Height="44" CornerRadius="10" Margin="0,0,0,16">
                                        <Border.Background>
                                            <SolidColorBrush Color="#FFF3EA"/>
                                        </Border.Background>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="#E8D0B8"/>
                                                <Setter Property="BorderThickness" Value="1.5"/>
                                            </Style>
                                        </Border.Style>
                                        <TextBox Background="Transparent"
                                                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="14" Padding="14,0"
                                                 Foreground="#5A3426"
                                                 BorderThickness="0"
                                                 VerticalContentAlignment="Center"/>
                                    </Border>

                                    <!-- Пароль -->
                                    <TextBlock Text="Пароль" FontSize="11" FontWeight="SemiBold"
                                               Foreground="#9A7060" Margin="0,0,0,4"/>
                                    <Border Height="44" CornerRadius="10"
                                            BorderBrush="#E8D0B8" BorderThickness="1.5"
                                            Margin="0,0,0,8">
                                        <Border.Background>
                                            <SolidColorBrush Color="#FFF3EA"/>
                                        </Border.Background>
                                        <PasswordBox Background="Transparent"
                                                     h:PasswordBoxHelper.BindPassword="True"
                                                     h:PasswordBoxHelper.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     FontSize="14" Padding="14,0"
                                                     Foreground="#5A3426"
                                                     BorderThickness="0"
                                                     VerticalContentAlignment="Center"/>
                                    </Border>

                                    <TextBlock Text="{Binding ErrorMessage}"
                                               Foreground="#C0392B" FontSize="12"
                                               TextWrapping="Wrap" Margin="0,4,0,12"
                                               Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

                                    <!-- Кнопка входа -->
                                    <Button Command="{Binding LoginCommand}"
                                            Height="46" Margin="0,4,0,20"
                                            Cursor="Hand" BorderThickness="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" CornerRadius="12">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#D6953D" Offset="0"/>
                                                            <GradientStop Color="#B87A2E" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#80D6953D" BlurRadius="12" ShadowDepth="0"/>
                                                    </Border.Effect>
                                                    <TextBlock Text="Войти" FontSize="15" FontWeight="Bold"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <Separator Background="#E8D0B8" Margin="0,0,0,16"/>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="Нет аккаунта? " FontSize="13"
                                                   Foreground="#9A7060" VerticalAlignment="Center"/>
                                        <Button Content="Зарегистрироваться"
                                                Command="{Binding GoToRegisterCommand}"
                                                Cursor="Hand" BorderThickness="0"
                                                Background="Transparent"
                                                FontSize="13" FontWeight="SemiBold"
                                                Foreground="#D6953D" Padding="4,0"/>
                                    </StackPanel>

                                </StackPanel>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
