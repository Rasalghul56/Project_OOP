<Window x:Class="Confectionery.Views.Auth.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:h="clr-namespace:Confectionery.Helpers"
        Title="Кондитерская — Вход"
        Width="400" SizeToContent="Height"
        MinHeight="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="{StaticResource PrimaryFont}">

    <Border Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Margin="24"
            Padding="28,24">
        <StackPanel>
            <TextBlock Text="Вход"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource TextDarkBrush}"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Введите email и пароль"
                       FontSize="13"
                       Foreground="{DynamicResource TextLightBrush}"
                       Margin="0,0,0,20"/>

            <TextBlock Text="Email" Style="{StaticResource LabelText}"/>
            <TextBox Style="{StaticResource ModernTextBox}"
                     Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,12"/>

            <TextBlock Text="Пароль" Style="{StaticResource LabelText}"/>
            <PasswordBox Style="{StaticResource ModernPasswordBox}"
                         h:PasswordBoxHelper.BindPassword="True"
                         h:PasswordBoxHelper.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,8"/>

            <TextBlock Text="{Binding ErrorMessage}"
                       Style="{StaticResource ErrorText}"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

            <Button Content="Войти"
                    Command="{Binding LoginCommand}"
                    Style="{StaticResource PrimaryButton}"
                    Height="42"
                    Margin="0,12,0,16"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Нет аккаунта? "
                           FontSize="13"
                           Foreground="{DynamicResource TextMediumBrush}"
                           VerticalAlignment="Center"/>
                <Button Content="Зарегистрироваться"
                        Command="{Binding GoToRegisterCommand}"
                        Cursor="Hand"
                        BorderThickness="0"
                        Background="Transparent"
                        Foreground="{DynamicResource AccentBrush}"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Padding="4,0"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
