<Window x:Class="Confectionery.Views.Auth.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:h="clr-namespace:Confectionery.Helpers"
        Title="Кондитерская — Регистрация"
        Width="400" SizeToContent="Height"
        MaxHeight="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="{StaticResource PrimaryFont}">

    <Border Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Margin="24"
            Padding="28,24">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Регистрация"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource TextDarkBrush}"
                           Margin="0,0,0,4"/>
                <TextBlock Text="Заполните поля ниже"
                           FontSize="13"
                           Foreground="{DynamicResource TextLightBrush}"
                           Margin="0,0,0,18"/>

                <TextBlock Text="Имя *" Style="{StaticResource LabelText}"/>
                <TextBox Style="{StaticResource ModernTextBox}"
                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,10"/>

                <TextBlock Text="Email *" Style="{StaticResource LabelText}"/>
                <TextBox Style="{StaticResource ModernTextBox}"
                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,10"/>

                <TextBlock Text="Телефон" Style="{StaticResource LabelText}"/>
                <TextBox Style="{StaticResource ModernTextBox}"
                         Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,10"/>

                <TextBlock Text="Пароль *" Style="{StaticResource LabelText}"/>
                <PasswordBox Style="{StaticResource ModernPasswordBox}"
                             h:PasswordBoxHelper.BindPassword="True"
                             h:PasswordBoxHelper.BoundPassword="{Binding Password, Mode=TwoWay}"
                             Margin="0,0,0,10"/>

                <TextBlock Text="Повторите пароль *" Style="{StaticResource LabelText}"/>
                <PasswordBox Style="{StaticResource ModernPasswordBox}"
                             h:PasswordBoxHelper.BindPassword="True"
                             h:PasswordBoxHelper.BoundPassword="{Binding ConfirmPassword, Mode=TwoWay}"
                             Margin="0,0,0,8"/>

                <TextBlock Text="{Binding ErrorMessage}"
                           Style="{StaticResource ErrorText}"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>
                <TextBlock Text="{Binding SuccessMessage}"
                           Style="{StaticResource SuccessText}"
                           Visibility="{Binding SuccessMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

                <Button Content="Зарегистрироваться"
                        Command="{Binding RegisterCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Height="42"
                        Margin="0,12,0,14"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Уже есть аккаунт? "
                               FontSize="13"
                               Foreground="{DynamicResource TextMediumBrush}"
                               VerticalAlignment="Center"/>
                    <Button Content="Войти"
                            Command="{Binding GoToLoginCommand}"
                            Cursor="Hand"
                            BorderThickness="0"
                            Background="Transparent"
                            Foreground="{DynamicResource AccentBrush}"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Padding="4,0"/>
                </StackPanel>

                <TextBlock Text="* — обязательные поля"
                           FontSize="11"
                           Foreground="{DynamicResource TextLightBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
