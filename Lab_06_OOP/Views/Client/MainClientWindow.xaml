<Window x:Class="Confectionery.Views.Client.MainClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Confectionery.ViewModels.Client"
        xmlns:conv="clr-namespace:Confectionery.Helpers"
        xmlns:local="clr-namespace:Confectionery.Views.Client"
        Title="Кондитерская"
        Width="1200" Height="740"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        FontFamily="{StaticResource PrimaryFont}"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:ShowcaseViewModel}">
            <local:ShowcaseView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CatalogViewModel}">
            <local:CatalogView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CartViewModel}">
            <local:CartView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:OrdersViewModel}">
            <local:OrdersView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProfileViewModel}">
            <local:ProfileView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ════════════════ Sidebar ════════════════ -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <DockPanel>
                <!-- Лого -->
                <StackPanel DockPanel.Dock="Top" Margin="0,24,0,20"
                            HorizontalAlignment="Center">
                    <TextBlock Text="🍰" FontSize="38" HorizontalAlignment="Center"/>
                    <TextBlock Text="Кондитерская" Foreground="White"
                               FontSize="14" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    <TextBlock Text="{Binding UserName}" Foreground="#B090B8"
                               FontSize="12" HorizontalAlignment="Center"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <Separator DockPanel.Dock="Top" Background="#40FFFFFF" Margin="16,0"/>

                <!-- Навигация -->
                <StackPanel DockPanel.Dock="Top" Margin="0,12,0,0">
                    <Button Style="{StaticResource SidebarButton}"
                            Command="{Binding ShowShowcaseCommand}">
                        <TextBlock Text="{DynamicResource Nav_Showcase}"/>
                    </Button>
                    <Button Style="{StaticResource SidebarButton}"
                            Command="{Binding ShowCatalogCommand}">
                        <TextBlock Text="{DynamicResource Nav_Catalog}"/>
                    </Button>

                    <!-- Корзина + бейдж -->
                    <Button Style="{StaticResource SidebarButton}"
                            Command="{Binding ShowCartCommand}"
                            HorizontalContentAlignment="Stretch">
                        <DockPanel LastChildFill="False">
                            <TextBlock DockPanel.Dock="Left"
                                       Text="{DynamicResource Nav_Cart}"
                                       VerticalAlignment="Center"/>
                            <Border DockPanel.Dock="Right"
                                    Style="{StaticResource CartBadge}"
                                    Visibility="{Binding CartHasItems,
                                        Converter={StaticResource BoolToVisibilityConverter}}"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding CartItemCount}"
                                           Foreground="White" FontSize="11"
                                           FontWeight="Bold" Padding="2,0"/>
                            </Border>
                        </DockPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarButton}"
                            Command="{Binding ShowOrdersCommand}">
                        <TextBlock Text="{DynamicResource Nav_Orders}"/>
                    </Button>

                    <Button Style="{StaticResource SidebarButton}"
                            Command="{Binding ShowProfileCommand}">
                        <TextBlock Text="{DynamicResource Nav_Profile}"/>
                    </Button>
                </StackPanel>

                <!-- Нижняя часть: тема / язык / выход -->
                <StackPanel DockPanel.Dock="Bottom" Margin="12,0,12,20">
                    <Separator Background="#40FFFFFF" Margin="4,0,4,10"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Style="{StaticResource SidebarButton}"
                                Command="{Binding ToggleThemeCommand}"
                                HorizontalContentAlignment="Center"
                                Padding="6,8">
                            <TextBlock Text="{DynamicResource Btn_Theme}" FontSize="12"/>
                        </Button>
                        <Button Grid.Column="2"
                                Style="{StaticResource SidebarButton}"
                                Command="{Binding ToggleLangCommand}"
                                HorizontalContentAlignment="Center"
                                Padding="6,8">
                            <TextBlock Text="{DynamicResource Btn_Lang}" FontSize="12"/>
                        </Button>
                    </Grid>
                    <Button Style="{StaticResource SidebarButton}"
                            Command="{Binding LogoutCommand}"
                            HorizontalContentAlignment="Center" Padding="6,8">
                        <TextBlock Text="🚪 Выйти" FontSize="12" Foreground="#FF8888"/>
                    </Button>
                </StackPanel>

                <Grid/><!-- spacer -->
            </DockPanel>
        </Border>

        <!-- ════════════════ Content ════════════════ -->
        <Border Grid.Column="1" Background="{DynamicResource BackgroundBrush}"
                Margin="0">
            <ContentControl Content="{Binding CurrentView}" Margin="24"
                            Style="{StaticResource FadeContentControl}"/>
        </Border>
    </Grid>
</Window>
