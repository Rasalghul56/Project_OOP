<UserControl x:Class="Confectionery.Views.Client.OrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:Confectionery.Models"
             FontFamily="{StaticResource PrimaryFont}">
    <DockPanel>
        <!-- Title row with unread-notification counter -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <TextBlock Text="{DynamicResource Orders_Title}"
                       Style="{StaticResource SectionHeader}"
                       Margin="0,0,0,0" DockPanel.Dock="Left"
                       VerticalAlignment="Center"/>
            <Border Style="{StaticResource OrdersBadge}"
                    DockPanel.Dock="Left"
                    Visibility="{Binding HasUnread,
                        Converter={StaticResource BoolToVisibilityConverter}}"
                    Margin="10,4,0,0" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding UnreadCount}"
                               Foreground="White" FontSize="12" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" новых" Foreground="White" FontSize="11"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </DockPanel>

        <Border DockPanel.Dock="Top"
                Background="{StaticResource AccentLightBrush}"
                CornerRadius="8" Padding="12,8" Margin="0,0,0,12"
                Visibility="{Binding StatusMessage, Converter={StaticResource NullToVisibilityConverter}}">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Список заказов -->
            <ListBox Grid.Column="0"
                     ItemsSource="{Binding Orders}"
                     SelectedItem="{Binding SelectedOrder}"
                     Background="Transparent" BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,8" Padding="14,12">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource Card}">
                                    <Style.Triggers>
                                        <!-- Highlight orders whose status has just changed -->
                                        <DataTrigger Binding="{Binding IsStatusChanged}" Value="True">
                                            <Setter Property="BorderBrush"
                                                    Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="BorderThickness" Value="2"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock FontWeight="Bold" FontSize="14"
                                               Foreground="{DynamicResource TextDarkBrush}">
                                        <Run Text="№"/>
                                        <Run Text="{Binding OrderNumber}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextMediumBrush}"
                                               Margin="0,2,0,0"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="{Binding Status, Converter={StaticResource OrderStatusConverter}}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AccentBrush}"/>
                                        <TextBlock Text=" 🔔"
                                                   FontSize="12"
                                                   Visibility="{Binding IsStatusChanged,
                                                       Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </StackPanel>
                                    <!-- Краткий состав -->
                                    <ItemsControl ItemsSource="{Binding OrderItems}" Margin="0,6,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock FontSize="11"
                                                           Foreground="{DynamicResource TextMediumBrush}">
                                                    <Run Text="• "/>
                                                    <Run Text="{Binding Product.Name}"/>
                                                    <Run Text=" × "/>
                                                    <Run Text="{Binding Quantity}"/>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Right"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TotalPrice, Converter={StaticResource PriceFormatConverter}}"
                                               FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}"
                                               HorizontalAlignment="Right"/>
                                    <Button FontSize="11" Padding="10,5"
                                            Margin="0,6,0,0"
                                            Command="{Binding DataContext.RepeatOrderCommand,
                                                RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button"
                                                   BasedOn="{StaticResource SecondaryButton}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Setter Property="Content"
                                                        Value="{DynamicResource Btn_Repeat}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}"
                                                                 Value="{x:Static models:OrderStatus.Completed}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Детали выбранного заказа -->
            <Border Grid.Column="2" Style="{StaticResource Card}" VerticalAlignment="Top"
                    Visibility="{Binding SelectedOrder, Converter={StaticResource NullToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Orders_Composition}"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource TextDarkBrush}"
                               Margin="0,0,0,12"/>
                    <ItemsControl ItemsSource="{Binding SelectedOrder.OrderItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Product.Name}"
                                               FontSize="13"
                                               Foreground="{DynamicResource TextDarkBrush}"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Grid.Column="1"
                                               Foreground="{DynamicResource TextMediumBrush}"
                                               FontSize="12" Margin="8,0,0,0">
                                        <Run Text="{Binding Quantity}"/>
                                        <Run Text=" × "/>
                                        <Run Text="{Binding UnitPrice, Converter={StaticResource PriceFormatConverter}}"/>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Separator Margin="0,8"/>
                    <Grid>
                        <TextBlock Text="{DynamicResource Orders_Total}" FontSize="13"
                                   Foreground="{DynamicResource TextMediumBrush}"/>
                        <TextBlock Text="{Binding SelectedOrder.TotalPrice,
                                       Converter={StaticResource PriceFormatConverter}}"
                                   HorizontalAlignment="Right"
                                   FontWeight="Bold" FontSize="14"
                                   Foreground="{StaticResource AccentBrush}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
