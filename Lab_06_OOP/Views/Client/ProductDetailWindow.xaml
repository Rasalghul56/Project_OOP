<Window x:Class="Confectionery.Views.Client.ProductDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Product.Name}"
        Width="680" Height="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="{StaticResource PrimaryFont}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24">

            <!-- Шапка: название + цена -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding Product.Category.Name}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding Product.Name}"
                               FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource TextDarkBrush}"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding AverageRating}"
                               FontSize="14" Foreground="#FFC107"
                               FontWeight="SemiBold" Margin="0,6,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right"
                            VerticalAlignment="Top" Margin="16,0,0,0">
                    <TextBlock Text="{Binding Product.Price, Converter={StaticResource PriceFormatConverter}}"
                               FontSize="26" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"
                               HorizontalAlignment="Right"/>
                    <TextBlock FontSize="12"
                               Foreground="{DynamicResource TextLightBrush}"
                               HorizontalAlignment="Right">
                        <Run Text="{Binding Product.Weight}"/>
                        <Run Text=" г"/>
                    </TextBlock>
                </StackPanel>
            </Grid>

            <!-- Изображение -->
            <Border CornerRadius="12" ClipToBounds="True" Height="200" Margin="0,0,0,16"
                    Background="{StaticResource AccentLightBrush}">
                <Grid>
                    <TextBlock Text="🍰" FontSize="64"
                               HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Product.ImagePath}"
                                                 Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Image Source="{Binding Product.ImagePath, Converter={StaticResource ImagePathConverter}}"
                           Stretch="UniformToFill"/>
                </Grid>
            </Border>

            <!-- Описание + Состав -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Описание" Style="{StaticResource LabelText}" FontSize="13"/>
                    <TextBlock Text="{Binding Product.Description}"
                               TextWrapping="Wrap" FontSize="14"
                               Foreground="{DynamicResource TextDarkBrush}"
                               LineHeight="22"/>
                    <Separator Margin="0,12"/>
                    <TextBlock Text="Состав" Style="{StaticResource LabelText}" FontSize="13"/>
                    <TextBlock Text="{Binding Product.Composition}"
                               TextWrapping="Wrap" FontSize="13"
                               Foreground="{DynamicResource TextMediumBrush}"/>
                </StackPanel>
            </Border>

            <!-- Кнопка в корзину -->
            <Button Content="🛒  В корзину"
                    Style="{StaticResource PrimaryButton}"
                    Height="44" Margin="0,0,0,24"
                    Command="{Binding AddToCartCommand}"/>

            <!-- Отзывы -->
            <TextBlock Text="Отзывы покупателей"
                       FontSize="18" FontWeight="Bold"
                       Foreground="{DynamicResource TextDarkBrush}"
                       Margin="0,0,0,12"/>

            <StackPanel Margin="0,0,0,12">
                <Button Content="✏️ Оставить отзыв"
                        Style="{StaticResource SecondaryButton}"
                        Padding="16,8" HorizontalAlignment="Left"
                        Command="{Binding ToggleReviewFormCommand}"
                        Visibility="{Binding CanAddReview,
                            Converter={StaticResource BoolToVisibilityConverter}}"/>
                <TextBlock Text="{Binding NoReviewReason}"
                           Foreground="{DynamicResource TextLightBrush}"
                           FontSize="12" Margin="0,4,0,0"
                           Visibility="{Binding NoReviewReason,
                               Converter={StaticResource NullToVisibilityConverter}}"/>
                <TextBlock Text="{Binding StatusMessage}"
                           Style="{StaticResource SuccessText}"
                           Margin="0,4,0,0"
                           Visibility="{Binding StatusMessage,
                               Converter={StaticResource NullToVisibilityConverter}}"/>
            </StackPanel>

            <!-- Форма отзыва -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16"
                    Visibility="{Binding IsReviewFormVisible,
                        Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="Оценка (1–5):" Style="{StaticResource LabelText}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Slider Minimum="1" Maximum="5" TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Value="{Binding NewRating}"
                                Width="160" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding NewRating}" Margin="10,0,0,0"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="#FFC107"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="⭐" FontSize="20"
                                   VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </StackPanel>
                    <TextBlock Text="Текст отзыва:" Style="{StaticResource LabelText}"/>
                    <TextBox Style="{StaticResource ModernTextBox}"
                             Text="{Binding NewText, UpdateSourceTrigger=PropertyChanged}"
                             Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                             Margin="0,0,0,12"/>
                    <Button Content="Отправить отзыв"
                            Style="{StaticResource PrimaryButton}"
                            Height="38" HorizontalAlignment="Left"
                            Padding="20,0"
                            Command="{Binding SubmitReviewCommand}"/>
                </StackPanel>
            </Border>

            <!-- Список отзывов -->
            <ItemsControl ItemsSource="{Binding Reviews}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,10">
                            <StackPanel>
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="{Binding User.Name}"
                                                   FontWeight="SemiBold" FontSize="14"
                                                   Foreground="{DynamicResource TextDarkBrush}"/>
                                        <TextBlock Text="{Binding CreatedAt, StringFormat=dd.MM.yyyy}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextLightBrush}"/>
                                    </StackPanel>
                                    <TextBlock HorizontalAlignment="Right"
                                               FontSize="14" Foreground="#FFC107"
                                               VerticalAlignment="Top">
                                        <Run Text="{Binding Rating}"/>
                                        <Run Text="⭐"/>
                                    </TextBlock>
                                </Grid>
                                <TextBlock Text="{Binding Text}"
                                           TextWrapping="Wrap" FontSize="13"
                                           Foreground="{DynamicResource TextMediumBrush}"
                                           Margin="0,8,0,0"/>
                                <Border Background="{StaticResource AccentLightBrush}"
                                        CornerRadius="8" Padding="12,8" Margin="0,10,0,0"
                                        Visibility="{Binding AdminReply,
                                            Converter={StaticResource NullToVisibilityConverter}}">
                                    <StackPanel>
                                        <TextBlock Text="Ответ администратора:"
                                                   FontWeight="SemiBold" FontSize="12"
                                                   Foreground="{StaticResource AccentBrush}"/>
                                        <TextBlock Text="{Binding AdminReply}"
                                                   TextWrapping="Wrap" FontSize="13"
                                                   Foreground="{DynamicResource TextDarkBrush}"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="Отзывов пока нет. Будьте первым!"
                       Foreground="{DynamicResource TextLightBrush}"
                       FontSize="13" HorizontalAlignment="Center"
                       Margin="0,16">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Reviews.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>
    </ScrollViewer>
</Window>
