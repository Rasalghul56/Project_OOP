<UserControl x:Class="Confectionery.Views.Client.CatalogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource PrimaryFont}">
    <DockPanel>
        <!-- Панель фильтров -->
        <Border DockPanel.Dock="Top" Margin="0,0,0,16" Padding="14,10"
                Style="{StaticResource Card}">
            <StackPanel>

                <!-- Ряд 1: pill-кнопки категорий -->
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              Margin="0,0,0,10">
                    <ItemsControl ItemsSource="{Binding Categories}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Margin="0,0,8,0" Cursor="Hand" BorderThickness="0"
                                        Command="{Binding DataContext.SelectCategoryCommand,
                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" CornerRadius="20" Padding="16,7"
                                                    BorderBrush="{DynamicResource AccentBrush}"
                                                    BorderThickness="1.5"
                                                    Background="Transparent">
                                                <TextBlock x:Name="Lbl"
                                                           Text="{Binding Name,
                                                               Converter={StaticResource CategoryNameConverter}}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentBrush}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <!-- Hover -->
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background"
                                                            Value="{DynamicResource AccentLightBrush}"/>
                                                </Trigger>
                                                <!-- Selected (after hover so it wins) -->
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{StaticResource ObjectEqualityConverter}">
                                                            <Binding Path="."/>
                                                            <Binding Path="DataContext.SelectedCategory"
                                                                     RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter TargetName="Bd" Property="Background"
                                                            Value="{DynamicResource AccentBrush}"/>
                                                    <Setter TargetName="Lbl" Property="Foreground"
                                                            Value="White"/>
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Ряд 2: поиск + сортировка + сброс -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="165"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Поиск -->
                    <Grid Grid.Column="0">
                        <TextBox Style="{StaticResource ModernTextBox}"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="36,0,12,0"/>
                        <TextBlock Text="🔍" VerticalAlignment="Center"
                                   Margin="12,0" Foreground="{DynamicResource TextLightBrush}"
                                   IsHitTestVisible="False"/>
                    </Grid>

                    <!-- Сортировка -->
                    <ComboBox Grid.Column="2"
                              ItemsSource="{Binding SortOptions}"
                              SelectedItem="{Binding SelectedSort}"/>

                    <!-- Сброс -->
                    <Button Grid.Column="4" Content="✕"
                            Style="{StaticResource IconButton}"
                            Width="34" Height="34" FontSize="13"
                            Command="{Binding ClearFiltersCommand}"
                            ToolTip="Сбросить все фильтры"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Список товаров -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Products}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Фиксированная высота — кнопки всегда на одном уровне -->
                        <Border Style="{StaticResource ProductCard}" Width="210" Height="320">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftDoubleClick"
                                    Command="{Binding DataContext.ShowDetailCommand,
                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}"/>
                            </Border.InputBindings>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <!-- Весь контент растягивается -->
                                    <RowDefinition Height="*"/>
                                    <!-- Кнопки всегда внизу -->
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Верхний контент -->
                                <StackPanel Grid.Row="0" VerticalAlignment="Top">
                                    <!-- Изображение / плейсхолдер -->
                                    <Border CornerRadius="8" ClipToBounds="True"
                                            Height="130" Margin="0,0,0,10"
                                            Background="{DynamicResource AccentLightBrush}">
                                        <Grid>
                                            <!-- Emoji: shown when no image path is set -->
                                            <TextBlock Text="{Binding Category.Name,
                                                           Converter={StaticResource CategoryEmojiConverter}}"
                                                       FontSize="48"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Opacity="0.75"
                                                       Visibility="{Binding ImagePath,
                                                           Converter={StaticResource InverseNullToVisibilityConverter2}}"/>
                                            <!-- Real image: shown when ImagePath is set -->
                                            <Image Stretch="UniformToFill"
                                                   Source="{Binding ImagePath, Converter={StaticResource ImagePathConverter}}"
                                                   Visibility="{Binding ImagePath,
                                                       Converter={StaticResource NullToVisibilityConverter}}"/>
                                        </Grid>
                                    </Border>

                                    <!-- Категория -->
                                    <TextBlock Text="{Binding Category.Name,
                                                   Converter={StaticResource CategoryNameConverter}}"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,0,3"/>

                                    <!-- Название (до 2 строк) -->
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="14" FontWeight="Bold"
                                               Foreground="{DynamicResource TextDarkBrush}"
                                               TextWrapping="Wrap"
                                               MaxHeight="46"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,0,4"/>

                                    <!-- Рейтинг и вес -->
                                    <TextBlock FontSize="11"
                                               Foreground="{DynamicResource TextMediumBrush}"
                                               Margin="0,0,0,6">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="⭐ {0} · {1} г">
                                                <Binding Path="Reviews" Converter="{StaticResource RatingToStarsConverter}"/>
                                                <Binding Path="Weight"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Нижний блок: цена + кнопки (всегда внизу) -->
                                <StackPanel Grid.Row="1">
                                    <TextBlock Text="{Binding Price, Converter={StaticResource PriceFormatConverter}}"
                                               FontSize="17" FontWeight="Bold"
                                               Foreground="{DynamicResource AccentBrush}"
                                               Margin="0,0,0,8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Content="{DynamicResource Btn_Detail}"
                                                Style="{StaticResource SecondaryButton}"
                                                Height="32" Padding="0" FontSize="12"
                                                Command="{Binding DataContext.ShowDetailCommand,
                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Grid.Column="2"
                                                Content="🛒"
                                                Style="{StaticResource PrimaryButton}"
                                                Width="36" Height="32" FontSize="15"
                                                Command="{Binding DataContext.AddToCartCommand,
                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="{DynamicResource Btn_AddToCart}"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
