<UserControl x:Class="Confectionery.Views.Client.CatalogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource PrimaryFont}">
    <DockPanel>
        <!-- Панель фильтров -->
        <Border DockPanel.Dock="Top" Margin="0,0,0,16" Padding="16"
                Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Поиск -->
                <Grid Grid.Column="0">
                    <TextBox Style="{StaticResource ModernTextBox}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Padding="36,0,12,0"/>
                    <TextBlock Text="🔍" VerticalAlignment="Center"
                               Margin="12,0" Foreground="{DynamicResource TextLightBrush}"
                               IsHitTestVisible="False"/>
                </Grid>

                <!-- Категория -->
                <ComboBox Grid.Column="2"
                          ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding SelectedCategory}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name,
                                Converter={StaticResource CategoryNameConverter}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Сортировка -->
                <ComboBox Grid.Column="4"
                          ItemsSource="{Binding SortOptions}"
                          SelectedItem="{Binding SelectedSort}"/>

                <!-- Кнопка сброса -->
                <Button Grid.Column="6" Content="✕"
                        Style="{StaticResource IconButton}"
                        Width="36" Height="36" FontSize="14"
                        Command="{Binding ClearFiltersCommand}"
                        ToolTip="Сбросить все фильтры"/>
            </Grid>
        </Border>

        <!-- Список товаров -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Products}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Фиксированная высота — кнопки всегда на одном уровне -->
                        <Border Style="{StaticResource ProductCard}" Width="210" Height="320">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftDoubleClick"
                                    Command="{Binding DataContext.ShowDetailCommand,
                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}"/>
                            </Border.InputBindings>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <!-- Весь контент растягивается -->
                                    <RowDefinition Height="*"/>
                                    <!-- Кнопки всегда внизу -->
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Верхний контент -->
                                <StackPanel Grid.Row="0" VerticalAlignment="Top">
                                    <!-- Изображение / плейсхолдер -->
                                    <Border CornerRadius="8" ClipToBounds="True"
                                            Height="130" Margin="0,0,0,10"
                                            Background="{DynamicResource AccentLightBrush}">
                                        <Grid>
                                            <TextBlock Text="🍰" FontSize="48"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       Opacity="0.55"/>
                                            <Image Stretch="UniformToFill"
                                                   Source="{Binding ImagePath, Converter={StaticResource ImagePathConverter}}">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ImagePath}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                        </Grid>
                                    </Border>

                                    <!-- Категория -->
                                    <TextBlock Text="{Binding Category.Name,
                                                   Converter={StaticResource CategoryNameConverter}}"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,0,3"/>

                                    <!-- Название (до 2 строк) -->
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="14" FontWeight="Bold"
                                               Foreground="{DynamicResource TextDarkBrush}"
                                               TextWrapping="Wrap"
                                               MaxHeight="46"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,0,4"/>

                                    <!-- Рейтинг и вес -->
                                    <TextBlock FontSize="11"
                                               Foreground="{DynamicResource TextMediumBrush}"
                                               Margin="0,0,0,6">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="⭐ {0} · {1} г">
                                                <Binding Path="Reviews" Converter="{StaticResource RatingToStarsConverter}"/>
                                                <Binding Path="Weight"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Нижний блок: цена + кнопки (всегда внизу) -->
                                <StackPanel Grid.Row="1">
                                    <TextBlock Text="{Binding Price, Converter={StaticResource PriceFormatConverter}}"
                                               FontSize="17" FontWeight="Bold"
                                               Foreground="{DynamicResource AccentBrush}"
                                               Margin="0,0,0,8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Content="{DynamicResource Btn_Detail}"
                                                Style="{StaticResource SecondaryButton}"
                                                Height="32" Padding="0" FontSize="12"
                                                Command="{Binding DataContext.ShowDetailCommand,
                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Grid.Column="2"
                                                Content="🛒"
                                                Style="{StaticResource PrimaryButton}"
                                                Width="36" Height="32" FontSize="15"
                                                Command="{Binding DataContext.AddToCartCommand,
                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="{DynamicResource Btn_AddToCart}"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
