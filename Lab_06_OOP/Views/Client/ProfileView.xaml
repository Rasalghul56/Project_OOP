<UserControl x:Class="Confectionery.Views.Client.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:Confectionery.Helpers"
             FontFamily="{StaticResource PrimaryFont}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,32,0">
            <TextBlock Text="{DynamicResource Profile_Title}" Style="{StaticResource SectionHeader}"/>

            <Border Width="80" Height="80" CornerRadius="40"
                    Background="{StaticResource AccentLightBrush}"
                    HorizontalAlignment="Left" Margin="0,0,0,20">
                <TextBlock Text="👤" FontSize="36"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>


            <TextBlock Text="{DynamicResource Profile_Email}" Style="{StaticResource LabelText}"/>
            <Border Background="{DynamicResource InputBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="8"
                    Padding="12,0" Height="40" Margin="0,0,0,12">
                <TextBlock Text="{Binding Email}" VerticalAlignment="Center"
                           FontSize="14" Foreground="{DynamicResource TextMediumBrush}"/>
            </Border>


            <TextBlock Text="{DynamicResource Profile_Name}" Style="{StaticResource LabelText}"/>
            <TextBox Style="{StaticResource ModernTextBox}"
                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                     MaxLength="100"
                     Margin="0,0,0,4"/>
            <TextBlock Text="{Binding NameError}"
                       Style="{StaticResource ErrorText}"
                       Margin="0,0,0,12"
                       Visibility="{Binding NameError, Converter={StaticResource NullToVisibilityConverter}}"/>


            <TextBlock Text="{DynamicResource Profile_Phone}" Style="{StaticResource LabelText}"/>
            <TextBox Style="{StaticResource ModernTextBox}"
                     Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="+375298677777"
                     Margin="0,0,0,12"/>

            <TextBlock Text="{Binding SuccessMessage}" Style="{StaticResource SuccessText}"
                       Visibility="{Binding SuccessMessage, Converter={StaticResource NullToVisibilityConverter}}"/>
            <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource ErrorText}"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

            <Button Content="{DynamicResource Profile_Save}"
                    Style="{StaticResource PrimaryButton}"
                    Height="42" Margin="0,4,0,28"
                    Command="{Binding SaveProfileCommand}"/>


            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Profile_ChangePass}"
                               FontSize="15" FontWeight="Bold"
                               Foreground="{DynamicResource TextDarkBrush}"
                               Margin="0,0,0,16"/>

                    <TextBlock Text="{DynamicResource Profile_OldPass}" Style="{StaticResource LabelText}"/>
                    <PasswordBox Style="{StaticResource ModernPasswordBox}"
                                 h:PasswordBoxHelper.BindPassword="True"
                                 h:PasswordBoxHelper.BoundPassword="{Binding OldPassword, Mode=TwoWay}"
                                 Margin="0,0,0,12"/>

                    <TextBlock Text="{DynamicResource Profile_NewPass}" Style="{StaticResource LabelText}"/>
                    <PasswordBox Style="{StaticResource ModernPasswordBox}"
                                 h:PasswordBoxHelper.BindPassword="True"
                                 h:PasswordBoxHelper.BoundPassword="{Binding NewPassword, Mode=TwoWay}"
                                 Margin="0,0,0,12"/>

                    <TextBlock Text="{DynamicResource Profile_ConfirmPass}" Style="{StaticResource LabelText}"/>
                    <PasswordBox Style="{StaticResource ModernPasswordBox}"
                                 h:PasswordBoxHelper.BindPassword="True"
                                 h:PasswordBoxHelper.BoundPassword="{Binding ConfirmNewPassword, Mode=TwoWay}"
                                 Margin="0,0,0,12"/>

                    <Button Content="{DynamicResource Profile_ChangePassBtn}"
                            Style="{StaticResource SecondaryButton}"
                            Height="40"
                            Command="{Binding ChangePasswordCommand}"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
