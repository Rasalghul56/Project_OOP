<UserControl x:Class="Confectionery.Views.Client.ShowcaseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource PrimaryFont}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,4,24">

            <!-- ── Hero-приветствие ─────────────────────────────────────────── -->
            <Border CornerRadius="16" Margin="0,0,0,24" Padding="28,22" ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#D6953D" Offset="0"/>
                        <GradientStop Color="#B87A2E" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect Color="#60D6953D" BlurRadius="20" ShadowDepth="4" Opacity="0.28"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding WelcomeText}"
                                   FontSize="22" FontWeight="Bold" Foreground="White"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="Свежие авторские десерты с доставкой по Минску"
                                   FontSize="14" Foreground="#FFF0D8"/>
                        <Button Content="🛍 Перейти в каталог"
                                Margin="0,18,0,0" Height="40" Width="180"
                                HorizontalAlignment="Left"
                                Cursor="Hand" BorderThickness="0"
                                Command="{Binding NavigateToCatalogCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" CornerRadius="10"
                                            Background="#40FFFFFF" Padding="16,0">
                                        <TextBlock Text="{TemplateBinding Content}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#60FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="🍰" FontSize="72"
                               Opacity="0.25" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ── Популярные ────────────────────────────────────────────────── -->
            <Grid Margin="0,0,0,6">
                <TextBlock Text="⭐ Популярные десерты" FontSize="17" FontWeight="Bold"
                           Foreground="{DynamicResource TextDarkBrush}"/>
                <Button Content="Все →" HorizontalAlignment="Right"
                        Style="{StaticResource SecondaryButton}" Padding="12,6"
                        FontSize="12"
                        Command="{Binding NavigateToCatalogCommand}"/>
            </Grid>
            <ItemsControl ItemsSource="{Binding PopularProducts}" Margin="0,0,0,24">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ProductCard}" Width="186" Height="290">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0">
                                    <Border CornerRadius="8" Height="110" Margin="0,0,0,8"
                                            ClipToBounds="True"
                                            Background="{DynamicResource AccentLightBrush}">
                                        <Grid>
                                            <TextBlock Text="{Binding Category.Name,
                                                           Converter={StaticResource CategoryEmojiConverter}}"
                                                       FontSize="40"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Opacity="0.75"
                                                       Visibility="{Binding ImagePath,
                                                           Converter={StaticResource InverseNullToVisibilityConverter2}}"/>
                                            <Image Stretch="UniformToFill"
                                                   Source="{Binding ImagePath, Converter={StaticResource ImagePathConverter}}"
                                                   Visibility="{Binding ImagePath,
                                                       Converter={StaticResource NullToVisibilityConverter}}"/>
                                        </Grid>
                                    </Border>
                                    <TextBlock Text="{Binding Category.Name, Converter={StaticResource CategoryNameConverter}}"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentBrush}"
                                               TextTrimming="CharacterEllipsis" Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="13" FontWeight="Bold"
                                               Foreground="{DynamicResource TextDarkBrush}"
                                               TextWrapping="Wrap" MaxHeight="42"
                                               TextTrimming="CharacterEllipsis" Margin="0,0,0,4"/>
                                    <TextBlock FontSize="10" Foreground="{DynamicResource TextMediumBrush}">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="⭐ {0}">
                                                <Binding Path="Reviews" Converter="{StaticResource RatingToStarsConverter}"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Grid.Row="1">
                                    <TextBlock Text="{Binding Price, Converter={StaticResource PriceFormatConverter}}"
                                               FontSize="15" FontWeight="Bold"
                                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="{DynamicResource Btn_Detail}"
                                                Style="{StaticResource SecondaryButton}"
                                                Height="30" Padding="0" FontSize="11"
                                                Command="{Binding DataContext.ShowDetailCommand,
                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Grid.Column="2" Content="🛒"
                                                Style="{StaticResource PrimaryButton}"
                                                Width="34" Height="30" FontSize="14"
                                                Command="{Binding DataContext.AddToCartCommand,
                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ── Новинки ────────────────────────────────────────────────────── -->
            <TextBlock Text="🆕 Новинки и сезонные позиции" FontSize="17" FontWeight="Bold"
                       Foreground="{DynamicResource TextDarkBrush}" Margin="0,0,0,10"/>
            <ItemsControl ItemsSource="{Binding NewProducts}" Margin="0,0,0,24">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4" Rows="1"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Margin="0,0,12,0" Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0">
                                    <Border CornerRadius="8" Height="90" Margin="0,0,0,10"
                                            Background="{DynamicResource AlternateBrush}">
                                        <TextBlock Text="✨" FontSize="36"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Background="{DynamicResource AccentBrush}"
                                            CornerRadius="4" Padding="6,2" Margin="0,0,0,6"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="NEW" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="13" FontWeight="Bold"
                                               Foreground="{DynamicResource TextDarkBrush}"
                                               TextWrapping="Wrap" MaxHeight="40"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Margin="0,8,0,0">
                                    <TextBlock Text="{Binding Price, Converter={StaticResource PriceFormatConverter}}"
                                               FontSize="15" FontWeight="Bold"
                                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,6"/>
                                    <Button Content="{DynamicResource Btn_AddToCart}"
                                            Style="{StaticResource PrimaryButton}"
                                            Height="32" FontSize="12"
                                            Command="{Binding DataContext.AddToCartCommand,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ── Персональные рекомендации ─────────────────────────────────── -->
            <StackPanel Visibility="{Binding RecommendedProducts.Count,
                            Converter={StaticResource NullToVisibilityConverter}}">
                <TextBlock Text="💡 Рекомендуем для вас" FontSize="17" FontWeight="Bold"
                           Foreground="{DynamicResource TextDarkBrush}" Margin="0,0,0,10"/>
                <ItemsControl ItemsSource="{Binding RecommendedProducts}" Margin="0,0,0,8">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4" Rows="1"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}" Margin="0,0,12,0" Padding="14">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0">
                                        <Border CornerRadius="8" Height="88" Margin="0,0,0,8"
                                                Background="{DynamicResource AlternateBrush}">
                                            <TextBlock Text="💝" FontSize="34"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="13" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextDarkBrush}"
                                                   TextWrapping="Wrap" MaxHeight="40"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Category.Name, Converter={StaticResource CategoryNameConverter}}"
                                                   FontSize="10" Foreground="{DynamicResource TextMediumBrush}"
                                                   Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Margin="0,8,0,0">
                                        <TextBlock Text="{Binding Price, Converter={StaticResource PriceFormatConverter}}"
                                                   FontSize="15" FontWeight="Bold"
                                                   Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Content="{DynamicResource Btn_Detail}"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Height="30" Padding="0" FontSize="11"
                                                    Command="{Binding DataContext.ShowDetailCommand,
                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Grid.Column="2" Content="🛒"
                                                    Style="{StaticResource PrimaryButton}"
                                                    Width="34" Height="30" FontSize="14"
                                                    Command="{Binding DataContext.AddToCartCommand,
                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
