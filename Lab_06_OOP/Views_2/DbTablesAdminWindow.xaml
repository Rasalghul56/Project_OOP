<Window x:Class="ConfectioneryShop.Views.DbTablesAdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Таблицы БД (лаб. 8–9)"
        Height="640"
        Width="900"
        MinHeight="360"
        MinWidth="560"
        WindowStartupLocation="CenterOwner"
        Icon="pack://application:,,,/Resources/app.ico">
    <DockPanel Margin="8">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <TextBlock Text="Навигация по таблицам (администратор)" FontWeight="Bold" Margin="0,0,0,6"/>
            <UniformGrid Columns="3" Margin="0,0,0,8">
                <Button Content="Категории" Margin="2" Padding="8,4" Click="TabCategories_Click"/>
                <Button Content="Производители" Margin="2" Padding="8,4" Click="TabManufacturers_Click"/>
                <Button Content="Товары" Margin="2" Padding="8,4" Click="TabProducts_Click"/>
            </UniformGrid>
            <WrapPanel Margin="0,0,0,6">
                <Button Content="Обновить" Margin="0,0,8,4" Padding="10,4" Command="{Binding RefreshCommand}"/>
                <Button Content="Добавить категорию" Margin="0,0,8,4" Padding="10,4" Command="{Binding AddCategoryCommand}"/>
                <Button Content="Удалить категорию" Margin="0,0,8,4" Padding="10,4" Command="{Binding DeleteCategoryCommand}"/>
                <Button Content="Добавить производителя" Margin="0,0,8,4" Padding="10,4" Command="{Binding AddManufacturerCommand}"/>
                <Button Content="Удалить производителя" Margin="0,0,8,4" Padding="10,4" Command="{Binding DeleteManufacturerCommand}"/>
            </WrapPanel>
            <Border BorderBrush="#CCC" BorderThickness="1" Padding="8" Background="#FAFAFA">
                <StackPanel>
                    <TextBlock Text="Запросы (параметры и хранимые процедуры)" FontWeight="Bold" Margin="0,0,0,4"/>
                    <WrapPanel VerticalAlignment="Center">
                        <TextBlock Text="Мин. цена:" VerticalAlignment="Center" Margin="0,0,6,4"/>
                        <TextBox Text="{Binding MinPriceFilter, UpdateSourceTrigger=PropertyChanged}" Width="70" Margin="0,0,12,4"/>
                        <TextBlock Text="Часть названия категории:" VerticalAlignment="Center" Margin="0,0,6,4"/>
                        <TextBox Text="{Binding CategoryPart, UpdateSourceTrigger=PropertyChanged}" Width="140" Margin="0,0,12,4"/>
                        <Button Content="Запрос с параметрами" Margin="0,0,8,4" Padding="8,4" Command="{Binding RunParamQueryCommand}"/>
                        <Button Content="ХП usp_Products_Filter" Margin="0,0,8,4" Padding="8,4" Command="{Binding RunSpFilterCommand}"/>
                        <Button Content="Статистика (ХП, async)" Margin="0,0,8,4" Padding="8,4" Command="{Binding LoadStatsAsyncCommand}"/>
                        <Button Content="Категории async" Padding="8,4" Command="{Binding LoadCategoriesSummaryAsyncCommand}"/>
                    </WrapPanel>
                    <TextBlock Text="{Binding StatsText}" TextWrapping="Wrap" Margin="0,6,0,0" FontSize="12"/>
                    <TextBlock Text="{Binding CategoriesSummary}" Margin="0,4,0,0" FontSize="11" Foreground="#555"/>
                </StackPanel>
            </Border>
            <Border BorderBrush="#C9A86C" BorderThickness="1" Padding="8" Background="#FFFDF8" Margin="0,8,0,0">
                <StackPanel>
                    <TextBlock Text="Entity Framework — лаб. 9 (Code First + LINQ to Entities)" FontWeight="Bold" Margin="0,0,0,6"/>
                    <TextBlock TextWrapping="Wrap" FontSize="11" Margin="0,0,0,6"
                               Text="Строка подключения: App.config → connectionStrings name=&quot;Confectionery&quot;. Подробности EDMX: Data_1\Лаб9_EDM_генерация.txt"/>
                    <WrapPanel Margin="0,0,0,6">
                        <TextBlock Text="Слова поиска (несколько через пробел):" VerticalAlignment="Center" Margin="0,0,6,4"/>
                        <TextBox Text="{Binding EfSearchWords, UpdateSourceTrigger=PropertyChanged}" Width="200" Margin="0,0,8,4"/>
                    </WrapPanel>
                    <WrapPanel>
                        <Button Content="EF: загрузить товары (async)" Margin="0,0,8,4" Padding="8,4" Command="{Binding EfLoadProductsAsyncCommand}"/>
                        <Button Content="EF: LINQ поиск" Margin="0,0,8,4" Padding="8,4" Command="{Binding EfLinqSearchCommand}"/>
                        <Button Content="EF: сортировка по цене" Margin="0,0,8,4" Padding="8,4" Command="{Binding EfSortByPriceCommand}"/>
                        <Button Content="EF: транзакция (ROLLBACK)" Margin="0,0,8,4" Padding="8,4" Command="{Binding EfTransactionDemoCommand}"/>
                        <Button Content="EF: CRUD метка" Margin="0,0,8,4" Padding="8,4" Command="{Binding EfCrudTagDemoCommand}"/>
                        <Button Content="EF: async на складе" Padding="8,4" Command="{Binding EfInStockCountAsyncCommand}"/>
                    </WrapPanel>
                    <TextBlock Text="{Binding EfLabResult}" TextWrapping="Wrap" Margin="0,6,0,0" FontSize="12"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="180"/>
            </Grid.RowDefinitions>

            <DataGrid x:Name="MainGrid"
                      Grid.Row="0"
                      ItemsSource="{Binding CurrentGrid}"
                      AutoGenerateColumns="True"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      CanUserSortColumns="True"
                      SelectionChanged="MainGrid_SelectionChanged"/>

            <GroupBox Grid.Row="1" Header="Результат запроса / ХП" Margin="0,8,0,0">
                <DataGrid ItemsSource="{Binding QueryResult}"
                          AutoGenerateColumns="True"
                          IsReadOnly="True"
                          CanUserSortColumns="True"/>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>
