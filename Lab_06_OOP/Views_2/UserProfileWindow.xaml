<Window x:Class="ConfectioneryShop.Views.UserProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource S_Profile_Title}"
        Height="360"
        Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/Resources/app.ico">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="{DynamicResource S_Profile_Header}" Style="{DynamicResource SectionHeader}" Margin="0,0,0,10"/>

        <Label Grid.Row="1" Grid.Column="0" Content="{DynamicResource S_Profile_FullName}" FontWeight="Bold"/>
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding UserProfile.FullName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

        <Label Grid.Row="2" Grid.Column="0" Content="{DynamicResource S_Profile_Email}" FontWeight="Bold"/>
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding UserProfile.Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

        <Label Grid.Row="3" Grid.Column="0" Content="{DynamicResource S_Profile_Phone}" FontWeight="Bold"/>
        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding UserProfile.Phone, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

        <Label Grid.Row="4" Grid.Column="0" Content="{DynamicResource S_Profile_Language}" FontWeight="Bold"/>
        <ComboBox Grid.Row="4" Grid.Column="1" ItemsSource="{Binding Languages}" SelectedItem="{Binding SelectedLanguage}" Margin="0,0,0,8"/>

        <Label Grid.Row="5" Grid.Column="0" Content="{DynamicResource S_Profile_Theme}" FontWeight="Bold" VerticalAlignment="Top"/>
        <ComboBox Grid.Row="5" Grid.Column="1" ItemsSource="{Binding Themes}" SelectedItem="{Binding SelectedTheme}" VerticalAlignment="Top"/>

        <Button Grid.Row="6" Grid.ColumnSpan="2" Content="{DynamicResource S_BtnClose}" Width="120" HorizontalAlignment="Center" Margin="0,14,0,0" Click="CloseWindow"/>
    </Grid>
</Window>
