<Window x:Class="ConfectioneryShop.Views.ProductAddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Lab_06_OOP"
        Title="{DynamicResource S_TitleAddProduct}"
        Height="681"
        Width="450"
        MinWidth="360"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Icon="pack://application:,,,/Resources/app.ico">
    <Window.Resources>
        <local:ProductImageConverter x:Key="ProductImageConverter"/>
        <Style x:Key="QtyTextStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Product.Quantity}" Value="0">
                    <Setter Property="Background" Value="#FFFFEFEF"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Content="{DynamicResource S_F_ShortName}" Grid.Row="0" Grid.Column="0" FontWeight="Bold"/>
        <TextBox Text="{Binding Product.ShortName}" Grid.Row="0" Grid.Column="1" Margin="0,0,0,10" Padding="5"/>

        <Label Content="{DynamicResource S_F_FullName}" Grid.Row="1" Grid.Column="0" FontWeight="Bold"/>
        <TextBox Text="{Binding Product.FullName}" Grid.Row="1" Grid.Column="1" Margin="0,0,0,10" Padding="5"/>

        <Label Content="{DynamicResource S_F_Description}" Grid.Row="2" Grid.Column="0" FontWeight="Bold"/>
        <TextBox Text="{Binding Product.Description}" Grid.Row="2" Grid.Column="1" Height="60"
                 TextWrapping="Wrap" Margin="0,0,0,10" Padding="5" AcceptsReturn="True"/>

        <Label Content="{DynamicResource S_F_Category}" Grid.Row="3" Grid.Column="0" FontWeight="Bold"/>
        <TextBox Text="{Binding Product.Category}" Grid.Row="3" Grid.Column="1" Margin="0,0,0,10" Padding="5"/>

        <Label Content="{DynamicResource S_F_Price}" Grid.Row="4" Grid.Column="0" FontWeight="Bold"/>
        <TextBox Text="{Binding Product.Price}" Grid.Row="4" Grid.Column="1" Margin="0,0,0,10" Padding="5"/>

        <Label Content="{DynamicResource S_F_Qty}" Grid.Row="5" Grid.Column="0" FontWeight="Bold"/>
        <TextBox Text="{Binding Product.Quantity}" Grid.Row="5" Grid.Column="1" Margin="0,0,0,10" Padding="5" Style="{StaticResource QtyTextStyle}"/>

        <Label Content="{DynamicResource S_F_Discount}" Grid.Row="6" Grid.Column="0" FontWeight="Bold"/>
        <TextBox Text="{Binding Product.Discount}" Grid.Row="6" Grid.Column="1" Margin="0,0,0,10" Padding="5"/>

        <Label Content="{DynamicResource S_F_Rating}" Grid.Row="7" Grid.Column="0" FontWeight="Bold"/>
        <TextBox Text="{Binding Product.Rating}" Grid.Row="7" Grid.Column="1" Margin="0,0,0,10" Padding="5"/>

        <Label Content="{DynamicResource S_F_Color}" Grid.Row="8" Grid.Column="0" FontWeight="Bold"/>
        <TextBox Text="{Binding Product.Color}" Grid.Row="8" Grid.Column="1" Margin="0,0,0,10" Padding="5"/>

        <Label Content="{DynamicResource S_F_Size}" Grid.Row="9" Grid.Column="0" FontWeight="Bold"/>
        <TextBox Text="{Binding Product.Size}" Grid.Row="9" Grid.Column="1" Margin="0,0,0,10" Padding="5"/>

        <Label Content="{DynamicResource S_F_Country}" Grid.Row="10" Grid.Column="0" FontWeight="Bold"/>
        <TextBox Text="{Binding Product.Country}" Grid.Row="10" Grid.Column="1" Margin="0,0,0,10" Padding="5"/>

        <Label Content="{DynamicResource S_F_Manufacturer}" Grid.Row="11" Grid.Column="0" FontWeight="Bold"/>
        <TextBox Text="{Binding Product.Manufacturer}" Grid.Row="11" Grid.Column="1" Margin="0,0,0,10" Padding="5"/>

        <Label Content="{DynamicResource S_F_Image}" Grid.Row="12" Grid.Column="0" FontWeight="Bold"/>
        <StackPanel Grid.Row="12" Grid.Column="1" Margin="0,0,0,10">
            <TextBox Text="{Binding Product.ImagePath}" Padding="5"/>
            <Button Content="{DynamicResource S_BtnLoadPhotoDb}" Margin="0,6,0,0" HorizontalAlignment="Left"
                    Command="{Binding PickPhotoCommand}" Padding="8,4"/>
        </StackPanel>

        <CheckBox Content="{DynamicResource S_F_OutOfStock}" Grid.Row="13" Grid.Column="1"
                  IsChecked="{Binding Product.IsOutOfStock}" Margin="0,0,0,10" HorizontalAlignment="Left"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                    Grid.Row="14" Grid.ColumnSpan="2" Margin="0,20,0,0">
            <Button x:Name="SaveButton" Content="{DynamicResource S_BtnSave}" Width="100" Margin="5" Padding="8,5"
                    Command="{Binding SaveCommand}" Background="#FF90EE90" FontWeight="Bold">
                <Button.Triggers>
                    <EventTrigger RoutedEvent="Button.Click">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.6" Duration="0:0:0.12" AutoReverse="True"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Button.Triggers>
            </Button>
            <Button Content="{DynamicResource S_BtnCancel}" Width="100" Margin="5" Padding="8,5"
                    Command="{Binding CancelCommand}" Background="#FFFFB6C1" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
    </ScrollViewer>
</Window>
